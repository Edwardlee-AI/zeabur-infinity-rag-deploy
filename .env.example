# Zeabur Infinity CPU service
PORT=1234
INFINITY_API_KEY=change-me

# Hugging Face model ids actually loaded by Infinity
EMBED_MODEL_ID=mixedbread-ai/mxbai-embed-large-v1
RERANK_MODEL_ID=Qwen/Qwen3-Reranker-0.6B

# API model names exposed to clients
EMBED_MODEL_NAME=text-embedding-mxbai-embed-large-v1
RERANK_MODEL_NAME=qwen3-reranker-0.6b

# CPU-friendly defaults
INFINITY_ENGINE=optimum
INFINITY_DEVICE=cpu
EMBED_BATCH_SIZE=8
RERANK_BATCH_SIZE=2
